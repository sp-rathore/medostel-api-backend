# Google Cloud Cost Report Configuration
# Copy this file to config.env and fill in your values

# GCP Configuration
PROJECT_ID=gen-lang-client-0064186167
REGION=us-central1
BILLING_ACCOUNT_ID=your_billing_account_id

# Email Configuration
RECIPIENT_EMAIL=shishupal.rathore@gmail.com
SENDGRID_API_KEY=SG.your_api_key_here

# Schedule (cron format)
# Default: 30 2 * * * (2:30 AM UTC / 8:00 AM IST)
SCHEDULE="30 2 * * *"

# BigQuery Configuration (optional)
# Enable for real billing data instead of sample data
BILLING_DATASET=billing_dataset
